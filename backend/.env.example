# PostgreSQL (required)
PGHOST=
PGPORT=5432
PGUSER=
PGPASSWORD=
PGDATABASE=xsell
# Optional: full URL instead of PG* vars above
# DATABASE_URL=postgresql://user:password@host:5432/xsell
# SSL mode: prefer (local), require (managed cloud)
PGSSLMODE=prefer

# Oracle (CONVERSIONS_FINAL exclusions — required when exclusions enabled)
ORACLE_USER=
ORACLE_PASSWORD=
ORACLE_HOST=
ORACLE_PORT=1521
ORACLE_SERVICE=
